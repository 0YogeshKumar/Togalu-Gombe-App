<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/theater_black">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Togalu Gombe"
        android:textColor="@color/puppet_gold"
        android:textSize="36sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ತೊಗಲು ಗೊಂಬೆಯಾಟ"
        android:textColor="@color/text_white"
        android:textSize="20sp"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLiveAssist"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="1. Live Assist (ದೃಶ್ಯಾವಳಿ)"
        android:textSize="16sp"
        app:backgroundTint="@color/theater_charcoal"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGallery"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="2. Puppet Gallery (ಗ್ಯಾಲರಿ)"
        android:textSize="16sp"
        app:backgroundTint="@color/theater_charcoal"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="3. Scan Puppet (ಸ್ಕ್ಯಾನ್ ಮಾಡಿ)"
        android:textSize="16sp"
        app:backgroundTint="@color/theater_charcoal"/>

</LinearLayout>