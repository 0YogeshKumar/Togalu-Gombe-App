<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/theater_black"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvScanTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Puppet Scanner"
        android:textColor="@color/puppet_gold"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp"/>

    <!-- Simulated Viewfinder Box -->
    <View
        android:id="@+id/viewFinder"
        android:layout_width="250dp"
        android:layout_height="350dp"
        android:layout_below="@id/tvScanTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:background="@android:color/transparent"
        android:backgroundTint="@android:color/transparent"
        android:foreground="?android:attr/selectableItemBackground"
        android:backgroundTintMode="add"
        style="@style/Widget.AppCompat.ProgressBar" />
        
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="[ Point at Puppet ]"
        android:textColor="@color/text_gray"
        android:textSize="18sp" />

    <!-- A simple border to make it look like a camera frame -->
    <View
        android:layout_width="250dp"
        android:layout_height="350dp"
        android:layout_below="@id/tvScanTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:background="#4DFFFFFF" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSimulateScan"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:text="Start Scan"
        android:textSize="18sp"
        app:backgroundTint="@color/theater_charcoal"/>

</RelativeLayout>